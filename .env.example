# Flask secret key — generate with: python -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Data directory for encrypted site storage (default: ./data)
CONNECTOR_DATA_DIR=./data

# Listen address (default: 127.0.0.1)
CONNECTOR_HOST=127.0.0.1

# Listen port (default: 5101)
CONNECTOR_PORT=5101

# SSH connection timeout in seconds (default: 10)
SSH_TIMEOUT=10

# SSH command execution timeout in seconds (default: 30)
SSH_COMMAND_TIMEOUT=30
